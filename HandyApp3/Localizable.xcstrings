    "All existing data on this device will be permanently deleted and replaced with the contents of the imported file. Type \"import\" to continue." : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los datos de este dispositivo serán eliminados permanentemente y reemplazados por el archivo importado. Escribe \"import\" para continuar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les données existantes sur cet appareil seront définitivement supprimées et remplacées par le fichier importé. Saisissez \"import\" pour continuer."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此设备上的所有现有数据将被永久删除，并替换为导入文件的内容。输入\"import\"继续。"
