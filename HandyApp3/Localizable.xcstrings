    "All data has been cleared and the app has been restored to its initial state." : {
      "extractionState" : "manual",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los datos han sido borrados y la app ha sido restaurada a su estado inicial."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les données ont été effacées et l'application a été restaurée dans son état initial."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有数据已清除，应用已恢复到初始状态。"
